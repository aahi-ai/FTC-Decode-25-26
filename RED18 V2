package org.firstinspires.ftc.teamcode.pedroPathing.Autos;

import com.bylazar.configurables.annotations.Configurable;
import com.bylazar.telemetry.PanelsTelemetry;
import com.bylazar.telemetry.TelemetryManager;
import com.pedropathing.follower.Follower;
import com.pedropathing.geometry.BezierCurve;
import com.pedropathing.geometry.BezierLine;
import com.pedropathing.geometry.Pose;
import com.pedropathing.paths.PathChain;
import com.qualcomm.hardware.limelightvision.LLResult;
import com.qualcomm.hardware.limelightvision.Limelight3A;
import com.qualcomm.hardware.rev.RevHubOrientationOnRobot;
import com.qualcomm.robotcore.eventloop.opmode.Autonomous;
import com.qualcomm.robotcore.eventloop.opmode.OpMode;
import com.qualcomm.robotcore.hardware.DcMotor;
import com.qualcomm.robotcore.hardware.DcMotorEx;
import com.qualcomm.robotcore.hardware.IMU;
import com.qualcomm.robotcore.hardware.Servo;
import com.qualcomm.robotcore.util.ElapsedTime;

import org.firstinspires.ftc.robotcore.external.navigation.AngleUnit;
import org.firstinspires.ftc.robotcore.external.navigation.YawPitchRollAngles;
import org.firstinspires.ftc.teamcode.pedroPathing.Constants;

@Autonomous(name = "RED18V2", group = "Autonomous")
@Configurable
public class RED18V2 extends OpMode {

    private TelemetryManager panelsTelemetry;
    private Follower follower;
    private int pathState;
    private Paths paths;
    private DcMotor intake, turret;
    private DcMotorEx shooter1, shooter2;
    private Servo gate;

    private Limelight3A limelight;
    private IMU imu;

    private long gateOpenTime = 0;
    private long waitStartTime = 0;

    // Turret aiming enabled only when robot is stationary and about to shoot
    private boolean turretAimingEnabled = false;

    // Turret auto-tracking constants
    private static final double TURRET_DEADZONE = 2.0;
    private static final double TURRET_KP = 0.018;
    private static final double TURRET_MAX_POWER = 0.35;

    // Positive offset shifts the aim point to the right of the goal (degrees)
    private static final double TURRET_TX_OFFSET = -3.0;

    // Shooter PID constants
    private static final double Kp = 0.003;
    private static final double Ki = 0.0005;
    private static final double Kd = 0.00015;
    private static final double MAX_VELOCITY = 2000;
    private double shooterSpeed = 0.5;
    private double targetVelocity1 = 0;
    private double targetVelocity2 = 0;
    private double integralSum1 = 0;
    private double integralSum2 = 0;
    private double lastError1 = 0;
    private double lastError2 = 0;
    private ElapsedTime pidTimer = new ElapsedTime();

    @Override
    public void init() {
        panelsTelemetry = PanelsTelemetry.INSTANCE.getTelemetry();

        follower = Constants.createFollower(hardwareMap);
        follower.setStartingPose(new Pose(110.579, 135.477, Math.toRadians(180)));
        paths = new Paths(follower);

        intake = hardwareMap.get(DcMotor.class, "intake");

        shooter1 = hardwareMap.get(DcMotorEx.class, "shooter1");
        shooter2 = hardwareMap.get(DcMotorEx.class, "shooter2");

        shooter1.setDirection(DcMotor.Direction.REVERSE);
        shooter2.setDirection(DcMotor.Direction.FORWARD);

        shooter1.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.FLOAT);
        shooter2.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.FLOAT);

        shooter1.setMode(DcMotor.RunMode.STOP_AND_RESET_ENCODER);
        shooter2.setMode(DcMotor.RunMode.STOP_AND_RESET_ENCODER);
        shooter1.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        shooter2.setMode(DcMotor.RunMode.RUN_USING_ENCODER);

        turret = hardwareMap.get(DcMotor.class, "turret");
        turret.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        turret.setDirection(DcMotor.Direction.FORWARD);
        turret.setPower(0);
        turret.setMode(DcMotor.RunMode.RUN_WITHOUT_ENCODER);

        // Gate starts CLOSED on init
        gate = hardwareMap.get(Servo.class, "gate");
        gate.setPosition(0);

        // Initialize Limelight
        limelight = hardwareMap.get(Limelight3A.class, "limelight");
        limelight.pipelineSwitch(0);

        // Initialize IMU
        imu = hardwareMap.get(IMU.class, "imu");
        RevHubOrientationOnRobot revHubOrientation = new RevHubOrientationOnRobot(
                RevHubOrientationOnRobot.LogoFacingDirection.RIGHT,
                RevHubOrientationOnRobot.UsbFacingDirection.UP);
        imu.initialize(new IMU.Parameters(revHubOrientation));

        pathState = 0;

        panelsTelemetry.debug("Status", "Initialized - Gate Closed");
        panelsTelemetry.update(telemetry);
    }

    @Override
    public void start() {
        follower.followPath(paths.Path1, 1.0, true);

        // First shot uses 0.49; all subsequent shots use 0.525
        shooterSpeed = 0.49;
        targetVelocity1 = MAX_VELOCITY * shooterSpeed;
        targetVelocity2 = MAX_VELOCITY * shooterSpeed;

        integralSum1 = 0;
        integralSum2 = 0;
        lastError1 = 0;
        lastError2 = 0;
        pidTimer.reset();

        intake.setPower(1.0);
        limelight.start();
    }

    @Override
    public void loop() {
        follower.update();
        updateShooterPID();
        updateTurretTracking();

        pathState = autonomousPathUpdate();

        Pose currentPose = follower.getPose();

        panelsTelemetry.debug("Path State", pathState);
        panelsTelemetry.debug("X", currentPose.getX());
        panelsTelemetry.debug("Y", currentPose.getY());
        panelsTelemetry.debug("Heading (deg)", Math.toDegrees(currentPose.getHeading()));
        panelsTelemetry.debug("Turret Power", turret.getPower());
        panelsTelemetry.debug("Gate Position", gate.getPosition());
        panelsTelemetry.debug("Shooter1 Velocity", shooter1.getVelocity());
        panelsTelemetry.debug("Shooter2 Velocity", shooter2.getVelocity());
        panelsTelemetry.update(telemetry);
    }

    private void updateShooterPID() {
        if (targetVelocity1 <= 0) {
            shooter1.setPower(0);
            shooter2.setPower(0);
            return;
        }

        double vel1 = Math.abs(shooter1.getVelocity());
        double vel2 = Math.abs(shooter2.getVelocity());

        double dt = pidTimer.seconds();
        pidTimer.reset();
        if (dt == 0 || dt > 0.1) dt = 0.02;

        double error1 = targetVelocity1 - vel1;
        double derivative1 = (error1 - lastError1) / dt;
        integralSum1 += error1 * dt;
        integralSum1 = Math.max(-500, Math.min(500, integralSum1));
        double power1 = (Kp * error1) + (Ki * integralSum1) + (Kd * derivative1);
        power1 = Math.max(0, Math.min(1.0, power1));
        lastError1 = error1;

        double error2 = targetVelocity2 - vel2;
        double derivative2 = (error2 - lastError2) / dt;
        integralSum2 += error2 * dt;
        integralSum2 = Math.max(-500, Math.min(500, integralSum2));
        double power2 = (Kp * error2) + (Ki * integralSum2) + (Kd * derivative2);
        power2 = Math.max(0, Math.min(1.0, power2));
        lastError2 = error2;

        shooter1.setPower(power1);
        shooter2.setPower(power2);
    }

    private void updateTurretTracking() {
        YawPitchRollAngles orientation = imu.getRobotYawPitchRollAngles();
        limelight.updateRobotOrientation(orientation.getYaw(AngleUnit.DEGREES));

        // Only aim turret when robot is stopped and preparing to / actively shooting
        if (!turretAimingEnabled) {
            turret.setPower(0);
            return;
        }

        LLResult llResult = limelight.getLatestResult();

        double turretCmd = 0.0;
        if (llResult != null && llResult.isValid()) {
            // Subtract offset so the turret settles TURRET_TX_OFFSET degrees right of center
            double tx = llResult.getTx() - TURRET_TX_OFFSET;

            turretCmd = tx * TURRET_KP;
            turretCmd = Math.max(-TURRET_MAX_POWER, Math.min(TURRET_MAX_POWER, turretCmd));

            if (Math.abs(tx) < TURRET_DEADZONE) {
                turretCmd = 0;
            }
        }
        turret.setPower(turretCmd);
        panelsTelemetry.debug("Turret TX (offset)", llResult != null && llResult.isValid() ? llResult.getTx() - TURRET_TX_OFFSET : 0);
    }

    public int autonomousPathUpdate() {
        switch (pathState) {

            // Case 0: Drive Path1 to first shooting position (aiming ON)
            case 0:
                turretAimingEnabled = true;
                if (!follower.isBusy()) {
                    gate.setPosition(1);
                    gateOpenTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 1: Wait 800ms gate open, then close and drive Path2
            // Switch shooter speed to 0.525 for all remaining shots
            case 1:
                turretAimingEnabled = true;
                if (System.currentTimeMillis() - gateOpenTime >= 800) {
                    gate.setPosition(0);
                    turretAimingEnabled = false;
                    shooterSpeed = 0.525;
                    targetVelocity1 = MAX_VELOCITY * shooterSpeed;
                    targetVelocity2 = MAX_VELOCITY * shooterSpeed;
                    integralSum1 = 0;
                    integralSum2 = 0;
                    follower.followPath(paths.Path2, 1.0, false);
                    pathState++;
                }
                break;

            // Case 2: Wait for Path2, then drive Path3
            case 2:
                turretAimingEnabled = false;
                if (!follower.isBusy()) {
                    follower.followPath(paths.Path3, 1.0, true);
                    pathState++;
                }
                break;

            // Case 3: Wait for Path3, then open gate (aiming ON)
            case 3:
                turretAimingEnabled = true;
                if (!follower.isBusy()) {
                    gate.setPosition(1);
                    gateOpenTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 4: Wait 800ms gate open, then close and drive Path4 at 0.8
            case 4:
                turretAimingEnabled = true;
                if (System.currentTimeMillis() - gateOpenTime >= 800) {
                    gate.setPosition(0);
                    turretAimingEnabled = false;
                    follower.followPath(paths.Path4, 0.8, false);
                    pathState++;
                }
                break;

            // Case 5: Wait for Path4 to finish, then pause
            case 5:
                turretAimingEnabled = false;
                if (!follower.isBusy()) {
                    waitStartTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 6: 0.67-second pause after Path4, then drive Path5 (aiming ON during return)
            case 6:
                turretAimingEnabled = false;
                if (System.currentTimeMillis() - waitStartTime >= 670) {
                    turretAimingEnabled = true;
                    follower.followPath(paths.Path5, 1.0, true);
                    pathState++;
                }
                break;

            // Case 7: Wait for Path5, then open gate (aiming ON)
            case 7:
                turretAimingEnabled = true;
                if (!follower.isBusy()) {
                    gate.setPosition(1);
                    gateOpenTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 8: Wait 1 second gate open, then close and drive Path6 at 0.8
            case 8:
                turretAimingEnabled = true;
                if (System.currentTimeMillis() - gateOpenTime >= 1000) {
                    gate.setPosition(0);
                    turretAimingEnabled = false;
                    follower.followPath(paths.Path6, 0.8, false);
                    pathState++;
                }
                break;

            // Case 9: Wait for Path6 to finish, then pause
            case 9:
                turretAimingEnabled = false;
                if (!follower.isBusy()) {
                    waitStartTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 10: 0.67-second pause after Path6, then drive Path7 (aiming ON during return)
            case 10:
                turretAimingEnabled = false;
                if (System.currentTimeMillis() - waitStartTime >= 670) {
                    turretAimingEnabled = true;
                    follower.followPath(paths.Path7, 1.0, true);
                    pathState++;
                }
                break;

            // Case 11: Wait for Path7, then open gate (aiming ON)
            case 11:
                turretAimingEnabled = true;
                if (!follower.isBusy()) {
                    gate.setPosition(1);
                    gateOpenTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 12: Wait 1 second gate open, then close and drive Path8 at 0.8
            case 12:
                turretAimingEnabled = true;
                if (System.currentTimeMillis() - gateOpenTime >= 1000) {
                    gate.setPosition(0);
                    turretAimingEnabled = false;
                    follower.followPath(paths.Path8, 0.8, false);
                    pathState++;
                }
                break;

            // Case 13: Wait for Path8 to finish, then pause
            case 13:
                turretAimingEnabled = false;
                if (!follower.isBusy()) {
                    waitStartTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 14: 0.67-second pause after Path8, then drive Path9 (aiming ON during return)
            case 14:
                turretAimingEnabled = false;
                if (System.currentTimeMillis() - waitStartTime >= 670) {
                    turretAimingEnabled = true;
                    follower.followPath(paths.Path9, 1.0, true);
                    pathState++;
                }
                break;

            // Case 15: Wait for Path9, then open gate (aiming ON)
            case 15:
                turretAimingEnabled = true;
                if (!follower.isBusy()) {
                    gate.setPosition(1);
                    gateOpenTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 16: Wait 1 second gate open, then close and drive Path10
            case 16:
                turretAimingEnabled = true;
                if (System.currentTimeMillis() - gateOpenTime >= 1000) {
                    gate.setPosition(0);
                    turretAimingEnabled = false;
                    follower.followPath(paths.Path10, 1.0, false);
                    pathState++;
                }
                break;

            // Case 17: Wait for Path10, then drive Path11 (aiming ON during Path11)
            case 17:
                turretAimingEnabled = false;
                if (!follower.isBusy()) {
                    turretAimingEnabled = true;
                    follower.followPath(paths.Path11, 1.0, true);
                    pathState++;
                }
                break;

            // Case 18: Wait for Path11, then open gate (aiming ON)
            case 18:
                turretAimingEnabled = true;
                if (!follower.isBusy()) {
                    gate.setPosition(1);
                    gateOpenTime = System.currentTimeMillis();
                    pathState++;
                }
                break;

            // Case 19: Hold gate open 1000ms, then close gate and drive Path12
            case 19:
                turretAimingEnabled = true;
                if (System.currentTimeMillis() - gateOpenTime >= 1000) {
                    gate.setPosition(0);
                    turretAimingEnabled = false;
                    follower.followPath(paths.Path12, 1.0, true);
                    pathState++;
                }
                break;

            // Case 20: Wait for Path12, then stop everything
            case 20:
                turretAimingEnabled = false;
                if (!follower.isBusy()) {
                    intake.setPower(0);
                    turret.setPower(0);
                    targetVelocity1 = 0;
                    targetVelocity2 = 0;
                    limelight.stop();
                    pathState++;
                }
                break;

            // Case 21: Idle
            case 21:
                break;
        }

        return pathState;
    }

    public static class Paths {
        public PathChain Path1;
        public PathChain Path2;
        public PathChain Path3;
        public PathChain Path4;
        public PathChain Path5;
        public PathChain Path6;
        public PathChain Path7;
        public PathChain Path8;
        public PathChain Path9;
        public PathChain Path10;
        public PathChain Path11;
        public PathChain Path12;

        public Paths(Follower follower) {
            Path1 = follower.pathBuilder().addPath(
                            new BezierLine(
                                    new Pose(110.579, 135.477),
                                    new Pose(88.748, 92.523)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(180))
                    .build();

            Path2 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(88.748, 92.523),
                                    new Pose(84.785, 53.159),
                                    new Pose(108.009, 58.579)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(180))
                    .build();

            Path3 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(108.009, 58.579),
                                    new Pose(85.701, 53.907),
                                    new Pose(84.075, 80.673)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(180))
                    .build();

            Path4 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(84.075, 80.673),
                                    new Pose(93.033, 54.472),
                                    new Pose(128.056, 60)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(191))
                    .build();

            Path5 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(128.056, 60),
                                    new Pose(95.093, 55.432),
                                    new Pose(85.402, 77.458)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(191), Math.toRadians(180))
                    .build();

            Path6 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(85.402, 77.458),
                                    new Pose(93.257, 55.441),
                                    new Pose(128.196, 60)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(191))
                    .build();

            Path7 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(128.196, 60),
                                    new Pose(94.720, 55.030),
                                    new Pose(85.187, 77.607)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(191), Math.toRadians(180))
                    .build();

            Path8 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(85.187, 77.607),
                                    new Pose(95.514, 54.771),
                                    new Pose(127.972, 60)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(191))
                    .build();

            Path9 = follower.pathBuilder().addPath(
                            new BezierCurve(
                                    new Pose(127.972, 60),
                                    new Pose(85.790, 55.056),
                                    new Pose(88.514, 80.738)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(191), Math.toRadians(180))
                    .build();

            Path10 = follower.pathBuilder().addPath(
                            new BezierLine(
                                    new Pose(88.514, 80.738),
                                    new Pose(118.019, 80.879)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(180))
                    .build();

            Path11 = follower.pathBuilder().addPath(
                            new BezierLine(
                                    new Pose(118.019, 80.879),
                                    new Pose(92.514, 80.776)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(180))
                    .build();

            Path12 = follower.pathBuilder().addPath(
                            new BezierLine(
                                    new Pose(92.514, 80.776),
                                    new Pose(107.776, 80.953)
                            )
                    ).setLinearHeadingInterpolation(Math.toRadians(180), Math.toRadians(180))
                    .build();
        }
    }
}
